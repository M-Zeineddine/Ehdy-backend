{
  "name": "ehdy-backend",
  "version": "1.0.0",
  "description": "Ehdy gifting platform backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern=tests/unit",
    "test:integration": "jest --runInBand --testPathPattern=tests/integration --testPathIgnorePatterns=tests/integration/auth",
    "test:auth": "jest --runInBand tests/integration/auth.test.js",
    "test:security": "jest --runInBand --testPathPattern=tests/security",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage",
    "migrate:up": "node src/migrations/run.js up",
    "seed": "node src/seeds/seed.js",
    "lint": "eslint src/ --ext .js",
    "build": "cd cms && npm install && npm run build",
    "cms:install": "cd cms && npm install",
    "cms:build": "cd cms && npm run build",
    "cms:dev": "cd cms && npm run dev"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "redis": "^4.6.10",
    "resend": "^6.9.3",
    "stripe": "^14.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^4.19.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
